# UbeChat Backend — Environment Configuration
# Copy to .env and fill in values

# Phoenix
SECRET_KEY_BASE=          # generate: mix phx.gen.secret
PHX_HOST=localhost
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://postgres:admin@localhost:5432/ubechat

# ScyllaDB
SCYLLA_HOSTS=127.0.0.1   # comma-separated for cluster: host1,host2,host3
SCYLLA_USER=scylla
SCYLLA_PASSWORD=

# JWT
JWT_SECRET=               # use a long random string in production
